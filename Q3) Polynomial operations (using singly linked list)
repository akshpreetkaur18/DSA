#include <stdio.h>
#include <stdlib.h>

struct node {
    int coeff, power;
    struct node* next;
};

struct node* create(int c, int p) {
    struct node* temp = (struct node*)malloc(sizeof(struct node));
    temp->coeff = c;
    temp->power = p;
    temp->next = NULL;
    return temp;
}

// Insert at end
struct node* insert(struct node* head, int c, int p) {
    struct node* temp = create(c, p);

    if(head == NULL) return temp;

    struct node* t = head;
    while(t->next != NULL)
        t = t->next;

    t->next = temp;
    return head;
}

// Display polynomial
void display(struct node* head) {
    while(head != NULL) {
        printf("%dx^%d", head->coeff, head->power);
        if(head->next != NULL) printf(" + ");
        head = head->next;
    }
    printf("\n");
}

// Addition
struct node* add(struct node* p1, struct node* p2) {
    struct node* res = NULL;

    while(p1 && p2) {
        if(p1->power == p2->power) {
            res = insert(res, p1->coeff + p2->coeff, p1->power);
            p1 = p1->next;
            p2 = p2->next;
        }
        else if(p1->power > p2->power) {
            res = insert(res, p1->coeff, p1->power);
            p1 = p1->next;
        } else {
            res = insert(res, p2->coeff, p2->power);
            p2 = p2->next;
        }
    }

    while(p1) {
        res = insert(res, p1->coeff, p1->power);
        p1 = p1->next;
    }

    while(p2) {
        res = insert(res, p2->coeff, p2->power);
        p2 = p2->next;
    }

    return res;
}

// Multiplication (basic)
struct node* multiply(struct node* p1, struct node* p2) {
    struct node* res = NULL;

    for(struct node* i = p1; i != NULL; i = i->next) {
        for(struct node* j = p2; j != NULL; j = j->next) {
            res = insert(res, i->coeff * j->coeff, i->power + j->power);
        }
    }
    return res;
}

int main() {
    struct node *p1 = NULL, *p2 = NULL, *res = NULL;
    int n, c, p, choice, i;

    while(1) {
        printf("\n1.Create P1\n2.Create P2\n3.Add\n4.Multiply\n5.Display\n6.Exit\n");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                scanf("%d", &n);
                for(i=0;i<n;i++) {
                    scanf("%d %d", &c, &p);
                    p1 = insert(p1,c,p);
                }
                break;

            case 2:
                scanf("%d", &n);
                for(i=0;i<n;i++) {
                    scanf("%d %d", &c, &p);
                    p2 = insert(p2,c,p);
                }
                break;

            case 3:
                res = add(p1,p2);
                display(res);
                break;

            case 4:
                res = multiply(p1,p2);
                display(res);
                break;

            case 5:
                display(p1);
                display(p2);
                break;

            case 6:
                return 0;
        }
    }
}
