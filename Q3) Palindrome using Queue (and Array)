#include <stdio.h>
#include <string.h>

#define MAX 100

char queue[MAX];
int front = 0, rear = -1;

void enqueue(char c) {
    queue[++rear] = c;
}

char dequeue() {
    return queue[front++];
}

int main() {
    char str[100];
    printf("Enter string: ");
    scanf("%s", str);

    int len = strlen(str);

    for(int i = 0; i < len; i++) {
        enqueue(str[i]);
    }

    int flag = 1;
    for(int i = len - 1; i >= 0; i--) {
        if(str[i] != dequeue()) {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Palindrome\n");
    else
        printf("Not Palindrome\n");

    return 0;
}
