#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node *prev, *next;
};

struct node* head = NULL;

struct node* create(int val) {
    struct node* temp = malloc(sizeof(struct node));
    temp->data = val;
    temp->next = temp->prev = temp;
    return temp;
}

// Insert Begin
void insertBegin() {
    int val; scanf("%d",&val);
    struct node* temp = create(val);

    if(head == NULL) {
        head = temp;
        return;
    }

    struct node* last = head->prev;

    temp->next = head;
    temp->prev = last;
    last->next = temp;
    head->prev = temp;

    head = temp;
}

// Insert End
void insertEnd() {
    int val; scanf("%d",&val);
    struct node* temp = create(val);

    if(head == NULL) {
        head = temp;
        return;
    }

    struct node* last = head->prev;

    last->next = temp;
    temp->prev = last;
    temp->next = head;
    head->prev = temp;
}

// Display
void display() {
    if(head == NULL) return;

    struct node* p = head;
    do {
        printf("%d <-> ", p->data);
        p = p->next;
    } while(p != head);

    printf("(circular)\n");
}

int main() {
    int ch;
    while(1) {
        printf("\n1.Insert Begin\n2.Insert End\n3.Display\n4.Exit\n");
        scanf("%d",&ch);

        switch(ch) {
            case 1: insertBegin(); break;
            case 2: insertEnd(); break;
            case 3: display(); break;
            case 4: return 0;
        }
    }
}
