#include <stdio.h>
#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

void insert(int x) {
    if((rear + 1) % MAX == front) {
        printf("Queue Overflow\n");
    } else {
        if(front == -1) front = 0;
        rear = (rear + 1) % MAX;
        queue[rear] = x;
    }
}

void delete() {
    if(front == -1) {
        printf("Queue Underflow\n");
    } else {
        printf("Deleted: %d\n", queue[front]);
        if(front == rear) {
            front = rear = -1;
        } else {
            front = (front + 1) % MAX;
        }
    }
}

void display() {
    if(front == -1) {
        printf("Queue is empty\n");
    } else {
        int i = front;
        while(1) {
            printf("%d ", queue[i]);
            if(i == rear) break;
            i = (i + 1) % MAX;
        }
        printf("\n");
    }
}

int main() {
    insert(1);
    insert(2);
    insert(3);
    display();
    delete();
    display();
    return 0;
}
